<%- include('partials/head',{title:musalla.name,canonicalPath:`/m/${musalla.guid}`}) %><%- include('partials/nav') %>
<main class="schedule-page weekly-schedule-page">
  <a class="back" href="/">‹ All musallas</a>
  <header class="musalla-head"><a class="mosque-icon big musalla-logo-link" href="/m/<%= musalla.guid %>" aria-label="View <%= musalla.name %>"><% if(musalla.logo_url){ %><img src="<%= musalla.logo_url %>" alt=""><% } else { %>⌂<% } %></a><div><p class="eyebrow"><%= isAdmin?'ADMIN VIEW':'IMAM ROSTER' %></p><div class="musalla-title"><h1><%= musalla.name %></h1><% if(isAdmin){ %><a class="profile-icon" href="/musallas/<%= musalla.id %>/profile" aria-label="Edit Musalla profile" title="Edit Musalla profile">⚙</a><% } %></div><p><%= musalla.address %></p><% if(musalla.timetable_url){ %><a class="timetable-link" href="<%= musalla.timetable_url %>" target="_blank" rel="noopener noreferrer">View prayer timetable ↗</a><% } %></div></header>
  <%
    const isoDate=value=>value.toISOString().slice(0,10);
    const addDays=(value,days)=>{ const result=new Date(value+'T12:00:00Z'); result.setUTCDate(result.getUTCDate()+days); return isoDate(result); };
    const days=Array.from({length:7},(_,index)=>addDays(date,index));
    const previousDate=addDays(date,-7)<firstDate?firstDate:addDays(date,-7);
    const nextDate=addDays(date,7)>finalWeekStart?finalWeekStart:addDays(date,7);
    const rangeFormatter=new Intl.DateTimeFormat('en-US',{month:'short',day:'numeric',timeZone:'UTC'});
    const dayFormatter=new Intl.DateTimeFormat('en-US',{weekday:'short',timeZone:'UTC'});
    const dayNumberFormatter=new Intl.DateTimeFormat('en-US',{day:'numeric',timeZone:'UTC'});
    const prayers=['Fajr','Zuhr','Asr','Maghrib','Isha'];
    const imamInitials=name=>(name||'Imam').trim().split(/\s+/).slice(0,2).map(part=>part[0]).join('').toUpperCase();
    const offersJumuah=[1,2,3].some(number=>musalla[`jumuah_${number}_enabled`]);
    const slotsByDate=Object.fromEntries(days.map(day=>[day,slots.filter(slot=>slot.prayer_date===day)]));
  %>
  <form class="week-picker"><button name="navigate" value="<%= previousDate %>" <%= date===firstDate?'disabled':'' %> aria-label="Previous week">‹</button><label class="date-select"><span class="date-display"><span aria-hidden="true">▣</span><%= rangeFormatter.format(new Date(date+'T12:00:00Z')) %> – <%= rangeFormatter.format(new Date(weekEndDate+'T12:00:00Z')) %></span><input type="date" name="date" aria-label="Choose week starting date" value="<%= date %>" min="<%= firstDate %>" max="<%= finalWeekStart %>" onchange="this.form.submit()"></label><button class="today-button <%= days.includes(today)?'current':'' %>" name="navigate" value="<%= today %>" aria-label="Show this week" title="This week">●</button><button name="navigate" value="<%= nextDate %>" <%= date===finalWeekStart?'disabled':'' %> aria-label="Next week">›</button></form>
  <p class="week-help"><%= canLead?'Tap an available prayer to lead. Tap your assignment again to release it.':'Prayer leadership for the next seven days.' %></p>
  <div class="weekly-table-wrap">
    <table class="weekly-table">
      <thead><tr><th scope="col">Day</th><% prayers.forEach(prayer=>{ %><th scope="col"><%= prayer %></th><% }) %></tr></thead>
      <tbody><% days.forEach(day=>{ const dayDate=new Date(day+'T12:00:00Z'); %><tr class="<%= day===today?'today-row':'' %>"><th scope="row"><span><%= dayFormatter.format(dayDate) %></span><b><%= dayNumberFormatter.format(dayDate) %></b></th><% prayers.forEach(prayer=>{ const fridayUnavailable=dayDate.getUTCDay()===5&&prayer==='Zuhr'&&!offersJumuah; const daySlots=fridayUnavailable?[]:slotsByDate[day].filter(slot=>prayer==='Zuhr'?(slot.prayer_name==='Zuhr'||slot.prayer_name.startsWith('Jumuah')):slot.prayer_name===prayer); %><td class="<%= fridayUnavailable?'unavailable-slot':'' %>"><% daySlots.forEach(s=>{ const mine=Number(s.imam_user_id)===Number(user.id); const canReplace=canLead&&s.imam_user_id&&!mine; const isJumuah=s.prayer_name.startsWith('Jumuah'); const imamColor=s.imam_user_id?`imam-color-${Number(s.imam_user_id)%8}`:''; const maxOptInDays=Math.floor((new Date(lastDate+'T12:00:00Z')-new Date(s.prayer_date+'T12:00:00Z'))/86400000)+1; %><form class="week-slot <%= s.imam_user_id?'claimed':'' %> <%= imamColor %>" action="/musallas/<%= musalla.id %>/slots/<%= s.id %>/opt-in" method="post" <%= canLead&&!s.imam_user_id&&!isJumuah?'data-multi-day-opt-in':'' %> <% if(canReplace){ %>data-confirm-title="Replace assigned imam?" data-confirm="<%= s.imam_name %> is currently assigned to lead <%= s.prayer_name %>. Would you like to replace them?" data-confirm-button="Replace imam"<% } %> data-prayer="<%= s.prayer_name %>" data-max-days="<%= Math.min(maxOptInDays,93) %>"><input type="hidden" name="days" value="1"><input type="hidden" name="return_date" value="<%= date %>"><% if(canReplace){ %><input type="hidden" name="replace_imam_id" value="<%= s.imam_user_id %>"><% } %><button <%= !canLead?'disabled':'' %> aria-label="<%= s.imam_name?(mine?`Release your ${s.prayer_name} assignment`:`${s.imam_name} is leading ${s.prayer_name}${canReplace?'; replace assignment':''}`):canLead?`Opt in to lead ${s.prayer_name}`:`${s.prayer_name} needs an imam` %>" title="<%= s.imam_name?(mine?'You are leading':`${s.imam_name} is leading`):canLead?'Opt in to lead':'Imam needed' %>"><% if(isJumuah){ %><small><%= s.prayer_name.replace('Jumuah ','J') %></small><% } %><span aria-hidden="true"><%= s.imam_name?imamInitials(s.imam_name):canLead?'+':'○' %></span></button></form><% }) %><% if(!daySlots.length){ %><span class="slot-missing"<% if(fridayUnavailable){ %> title="No Jumuah offered" aria-label="No Friday prayer offered"<% } %>>—</span><% } %></td><% }) %></tr><% }) %></tbody>
    </table>
  </div>
  <% if(isAdmin){ %><form class="schedule-reminder" action="/musallas/<%= musalla.id %>/remind-imams" method="post" data-confirm-title="Remind active Imams?" data-confirm="Send the seven-day schedule to all active Imam members and ask them to fill open prayer slots." data-confirm-button="Send reminder"><input type="hidden" name="date" value="<%= date %>"><button class="button" type="submit"><span aria-hidden="true">◉</span> Remind Imams</button></form><% } %>
  <dialog class="opt-in-dialog" id="opt-in-dialog"><form method="dialog" class="dialog-card"><button class="dialog-close" value="cancel" aria-label="Close">×</button><p class="eyebrow">OPT IN</p><h2 id="opt-in-title">Lead salah</h2><p>How many consecutive days would you like to lead this salah?</p><label>Number of days<input id="opt-in-days" type="number" min="1" value="1" required inputmode="numeric"></label><div class="dialog-actions"><button class="button secondary" value="cancel">Cancel</button><button class="button" id="confirm-opt-in" value="default">Confirm</button></div></form></dialog>
</main>
<script src="/musalla.js"></script>
<%- include('partials/foot') %>

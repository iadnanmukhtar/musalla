<%- include('partials/head',{title:musalla.name}) %><%- include('partials/nav') %>
<main class="schedule-page">
  <a class="back" href="/">‹ All musallas</a>
  <header class="musalla-head"><div class="mosque-icon big"><% if(musalla.logo_url){ %><img src="<%= musalla.logo_url %>" alt=""><% } else { %>⌂<% } %></div><div><p class="eyebrow"><%= isAdmin?'ADMIN VIEW':'IMAM ROSTER' %></p><div class="musalla-title"><h1><%= musalla.name %></h1><% if(isAdmin){ %><a class="profile-icon" href="/musallas/<%= musalla.id %>/profile" aria-label="Edit Musalla profile" title="Edit Musalla profile">⚙</a><% } %></div><p><%= musalla.address %></p><% if(musalla.timetable_url){ %><a class="timetable-link" href="<%= musalla.timetable_url %>" target="_blank" rel="noopener noreferrer">View prayer timetable ↗</a><% } %></div></header>
  <% const previousDate=new Date(new Date(date+'T12:00:00Z').getTime()-86400000).toISOString().slice(0,10); const nextDate=new Date(new Date(date+'T12:00:00Z').getTime()+86400000).toISOString().slice(0,10); const dateLabel=new Intl.DateTimeFormat('en-US',{weekday:'long',month:'short',day:'numeric',timeZone:'UTC'}).format(new Date(date+'T12:00:00Z')); %>
  <form class="date-picker"><button name="navigate" value="<%= previousDate %>" <%= date===firstDate?'disabled':'' %> aria-label="Previous day">‹</button><label class="date-select"><span class="date-display"><span aria-hidden="true">▣</span><%= dateLabel %></span><input type="date" name="date" aria-label="Choose schedule date" value="<%= date %>" min="<%= firstDate %>" max="<%= lastDate %>" onchange="this.form.submit()"></label><button class="today-button <%= date===today?'current':'' %>" name="navigate" value="<%= today %>" aria-label="Go to today's schedule" title="Today">●</button><button name="navigate" value="<%= nextDate %>" <%= date===lastDate?'disabled':'' %> aria-label="Next day">›</button></form>
  <% const maxOptInDays=Math.floor((new Date(lastDate+'T12:00:00Z')-new Date(date+'T12:00:00Z'))/86400000)+1; %>
  <div class="prayers"><% slots.forEach(s=>{ const mine=s.imam_user_id===user.id; %><article class="prayer <%= s.imam_user_id?'claimed':'' %>"><div class="prayer-name"><h3><%= s.prayer_name %></h3><% if(s.imam_name){ %><p><span class="mini-avatar"><%= s.imam_name[0] %></span><%= mine?'You are leading':s.imam_name %></p><% } else { %><p>Imam needed</p><% } %></div><form action="/musallas/<%= musalla.id %>/slots/<%= s.id %>/opt-in" method="post" <%= canLead&&!s.imam_user_id?'data-multi-day-opt-in':'' %> data-prayer="<%= s.prayer_name %>" data-max-days="<%= Math.min(maxOptInDays,93) %>"><input type="hidden" name="days" value="1"><button class="optin <%= mine?'mine':'' %>" <%= !canLead||(s.imam_user_id&&!mine)?'disabled':'' %>><%= mine?'✓':s.imam_user_id?'Assigned':canLead?'I can lead':'Imam role required' %></button></form></article><% }) %><% if(!slots.length){ %><div class="empty"><h3>Schedule unavailable</h3><p>Please reload the page or contact an administrator.</p></div><% } %></div>
  <form class="leave-musalla" action="/musallas/<%= musalla.id %>/leave" method="post" onsubmit="return confirm('Leave <%= musalla.name.replace(/'/g,'\\&#39;') %>? Your future prayer assignments at this Musalla will be cleared.')"><button>Leave this Musalla</button></form>
  <dialog class="opt-in-dialog" id="opt-in-dialog"><form method="dialog" class="dialog-card"><button class="dialog-close" value="cancel" aria-label="Close">×</button><p class="eyebrow">OPT IN</p><h2 id="opt-in-title">Lead salah</h2><p>How many consecutive days would you like to lead this salah?</p><label>Number of days<input id="opt-in-days" type="number" min="1" value="1" required inputmode="numeric"></label><div class="dialog-actions"><button class="button secondary" value="cancel">Cancel</button><button class="button" id="confirm-opt-in" value="default">Confirm</button></div></form></dialog>
</main>
<script src="/musalla.js"></script>
<%- include('partials/foot') %>

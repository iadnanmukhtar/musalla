<%- include('partials/head',{title:'Sign in'}) %><main class="login"><div class="hero-mark"><img src="/icon.svg" alt=""></div><h1>Musalla</h1><p class="lead">Serve your community, one salah at a time.</p><div class="login-card"><h2>Sign in</h2><p>Use your Google account to join your Musalla and volunteer to lead salah.</p><% if(googleReady){ %><a class="button google" href="/auth/google"><span>G</span> Continue with Google</a><div class="or"><span>New Musalla</span></div><a class="button secondary" href="/auth/google?next=/register-musalla">Register a Musalla</a><% } else { %><button class="button google" disabled><span>G</span> Google sign-in not configured</button><button class="button secondary" disabled>Register a Musalla</button><% } %><% if(testMode){ %><div class="test-login"><div class="or"><span>Test mode</span></div><p>Use a seeded role to test both test Musallas alongside current data.</p><div class="test-login-actions"><form action="/auth/test/imam" method="post"><button class="button secondary">Log in as test imam</button></form><form action="/auth/test/admin" method="post"><button class="button secondary">Log in as test admin</button></form></div></div><% } %></div></main><%- include('partials/foot') %>

<%- include('partials/head',{title:`${musalla.name} members`}) %><%- include('partials/nav') %>
<main><a class="back" href="/musallas/<%= musalla.id %>">‹ Back to schedule</a><header class="page-head"><p class="eyebrow"><%= musalla.name.toUpperCase() %></p><h1>Members</h1><p>Manage membership requests, imams, and administrators.</p></header>
<% if(requests.length){ %><section class="membership-request-list"><div class="section-title"><h2>Requests</h2><span><%= requests.length %></span></div><div class="surface"><% requests.forEach(request=>{ %><article class="membership-request"><div class="member-summary"><span class="mini-avatar"><% if(request.avatar_url){ %><img src="<%= request.avatar_url %>" alt=""><% } else { %><%= request.name[0] %><% } %></span><div><b><%= request.name %></b><small><%= request.email %></small></div></div><div class="request-actions"><form action="/musallas/<%= musalla.id %>/membership-requests/<%= request.id %>/approve" method="post"><button class="chip approve">Approve</button></form><form action="/musallas/<%= musalla.id %>/membership-requests/<%= request.id %>/deny" method="post"><button class="chip danger">Deny</button></form></div></article><% }) %></div></section><% } %>
<div class="section-title"><h2>Current members</h2><span><%= members.length %></span></div><section class="surface members-list"><% members.forEach(m=>{ const roles=m.role.split(','); %><article class="member"><div class="member-summary"><span class="mini-avatar"><% if(m.avatar_url){ %><img src="<%= m.avatar_url %>" alt=""><% } else { %><%= m.name[0] %><% } %></span><div><a class="member-name" href="/musallas/<%= musalla.id %>/members/<%= m.id %>/profile"><%= m.name %></a><small><%= roles.join(' · ') %> · <%= m.email %><% if(m.status!=='active'){ %> · disabled<% } %></small></div></div><% if(m.id!==user.id){ %><div class="member-actions"><form action="/musallas/<%= musalla.id %>/members/<%= m.id %>/status" method="post"><input type="hidden" name="status" value="<%= m.status==='active'?'disabled':'active' %>"><button class="chip"><%= m.status==='active'?'Disable':'Enable' %></button></form><% if(roles.includes('imam')&&!roles.includes('admin')){ %><form action="/musallas/<%= musalla.id %>/members/<%= m.id %>/remove" method="post" onsubmit="return confirm('Remove <%= m.name.replace(/'/g,'\\&#39;') %> from this Musalla? Their future prayer assignments will be cleared.')"><button class="chip danger">Remove</button></form><% } %></div><% } %></article><% }) %><% if(!members.length){ %><div class="empty">No approved members yet.</div><% } %></section></main>
<%- include('partials/foot') %>

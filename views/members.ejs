<%- include('partials/head',{title:`${musalla.name} members`}) %><%- include('partials/nav') %>
<main>
  <a class="back" href="/musallas/<%= musalla.id %>">‹ Back to schedule</a>
  <header class="page-head"><p class="eyebrow"><%= musalla.name.toUpperCase() %></p><h1>Members</h1><p>Manage membership requests, imams, and administrators.</p></header>
  <section class="invite-panel"><button class="button secondary" id="open-invite" type="button">Invite an Imam</button><dialog class="invite-dialog" id="invite-dialog"><div class="dialog-card" data-invite-message="al-salamu alaykum! You are invited to join <%= musalla.name %> as an Imam and opt in to lead prayers. Join here: <%= inviteUrl %>"><button class="dialog-close" id="close-invite" type="button" aria-label="Close">×</button><p class="eyebrow">IMAM INVITATION</p><h2>Invite to <%= musalla.name %></h2><p>Share this invitation through your preferred app.</p><textarea id="invite-message" rows="5" readonly></textarea><div class="invite-actions"><button class="button secondary" id="share-invite" type="button">Share invitation</button></div><p class="invite-feedback" id="invite-feedback" role="status"></p></div></dialog></section>
  <% if(requests.length){ %>
    <section class="membership-request-list"><div class="section-title"><h2>Requests</h2><span><%= requests.length %></span></div><div class="surface">
      <% requests.forEach(request=>{ const profileUrl=`/musallas/${musalla.id}/members/${request.id}/profile`; %>
        <article class="membership-request"><div class="member-summary"><a class="member-avatar-link" href="<%= profileUrl %>" aria-label="View <%= request.name %>'s profile"><span class="mini-avatar"><% if(request.avatar_url){ %><img src="<%= request.avatar_url %>" alt=""><% } else { %><%= request.name[0] %><% } %></span></a><div><a class="member-name" href="<%= profileUrl %>"><%= request.name %></a><small><%= request.email %><% if(request.requested_role==='imam'){ %> · Invited Imam<% } %></small></div></div><div class="request-actions"><form action="/musallas/<%= musalla.id %>/membership-requests/<%= request.id %>/approve" method="post" class="approval-form" data-confirm-title="Approve <%= request.name %>?" data-confirm="This membership request will be approved with the selected roles." data-confirm-button="Approve membership"><div class="role-options"><label class="role-option"><input type="checkbox" name="roles" value="imam" <%= request.requested_role==='imam'?'checked':'' %>> Imam</label><label class="role-option"><input type="checkbox" name="roles" value="admin"> Administrator</label></div><button class="chip approve">Approve membership</button></form><form action="/musallas/<%= musalla.id %>/membership-requests/<%= request.id %>/deny" method="post" data-confirm-title="Deny <%= request.name %>?" data-confirm="This membership request will be denied." data-confirm-button="Deny request" data-confirm-style="danger"><button class="chip danger">Deny</button></form></div></article>
      <% }) %>
    </div></section>
  <% } %>
  <div class="section-title"><h2>Current members</h2><span><%= members.length %></span></div>
  <section class="surface members-list">
    <% members.forEach(m=>{ const roles=m.role.split(','); const profileUrl=`/musallas/${musalla.id}/members/${m.id}/profile`; %>
      <article class="member"><div class="member-summary"><a class="member-avatar-link" href="<%= profileUrl %>" aria-label="View <%= m.name %>'s profile"><span class="mini-avatar"><% if(m.avatar_url){ %><img src="<%= m.avatar_url %>" alt=""><% } else { %><%= m.name[0] %><% } %></span></a><div><a class="member-name" href="<%= profileUrl %>"><%= m.name %></a><small><%= roles.join(' · ') %> · <%= m.email %><% if(m.status!=='active'){ %> · disabled<% } %></small></div></div><% if(m.id!==user.id){ %><div class="member-actions"><form action="/musallas/<%= musalla.id %>/members/<%= m.id %>/status" method="post" data-confirm-title="<%= m.status==='active'?'Disable':'Enable' %> <%= m.name %>?" data-confirm="<%= m.status==='active'?'This member will lose access to the Musalla until re-enabled.':'This member will regain access to the Musalla.' %>" data-confirm-button="<%= m.status==='active'?'Disable member':'Enable member' %>" <%- m.status==='active'?'data-confirm-style="danger"':'' %>><input type="hidden" name="status" value="<%= m.status==='active'?'disabled':'active' %>"><button class="chip"><%= m.status==='active'?'Disable':'Enable' %></button></form><% if(roles.includes('imam')&&!roles.includes('admin')){ %><form action="/musallas/<%= musalla.id %>/members/<%= m.id %>/remove" method="post" data-confirm-title="Remove <%= m.name %>?" data-confirm="Their membership will be removed and future prayer assignments will be cleared." data-confirm-button="Remove member" data-confirm-style="danger"><button class="chip danger">Remove</button></form><% } %></div><% } %></article>
    <% }) %>
    <% if(!members.length){ %><div class="empty">No approved members yet.</div><% } %>
  </section>
  <form class="leave-musalla" action="/musallas/<%= musalla.id %>/leave" method="post" data-confirm-title="Leave this Musalla?" data-confirm="Your future prayer assignments at <%= musalla.name %> will be cleared." data-confirm-button="Leave Musalla" data-confirm-style="danger"><button>Leave the Musalla</button></form>
</main>
<script src="/members.js?v=4"></script>
<%- include('partials/foot') %>

<%- include('partials/head',{title:'Choose a Musalla'}) %><%- include('partials/nav') %>
<main>
  <header class="page-head"><p class="eyebrow">WELCOME</p><h1>Choose your Musalla</h1><p>Select at least one Musalla and send a membership request. An administrator must approve it before assigning your role.</p></header>
  <form action="/register/musallas" method="post" class="registration-form" id="registration-form" data-confirm-title="Send membership request?" data-confirm="Your request will be sent to the selected Musalla administrators for approval." data-confirm-button="Send request">
    <div class="registration-musallas">
      <% musallas.forEach(m=>{ %><label class="registration-card"><input type="checkbox" name="musalla_ids" value="<%= m.id %>"><span class="mosque-icon"><% if(m.logo_url){ %><img src="<%= m.logo_url %>" alt=""><% } else { %>⌂<% } %></span><span><b><%= m.name %></b><small><%= m.address||'Address not set' %></small></span></label><% }) %>
      <% if(!musallas.length){ %><div class="empty">No Musallas are currently available. Please contact an administrator.</div><% } %>
    </div>
    <p class="form-error" id="registration-error" hidden>Select at least one Musalla.</p>
    <button class="button" <%= !musallas.length?'disabled':'' %>>Send request</button>
  </form>
</main>
<script src="/registration.js"></script><%- include('partials/foot') %>

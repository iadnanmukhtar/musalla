<%- include('partials/head',{title:musalla.name,isPublic:true,canonicalPath:`/m/${musalla.guid}`,description:musalla.about||`${musalla.name}${musalla.address?` in ${musalla.address}`:''} is part of the Musalla community.`,structuredData}) %>
<main class="public-musalla">
  <nav class="public-links" aria-label="Public navigation"><a class="public-brand" href="/"><span class="brand-mark"><img src="/icon.svg" alt="Musalla"></span><span>Musalla</span></a><a href="/about">About</a></nav>
  <section class="public-musalla-hero">
    <div class="mosque-icon public-musalla-logo"><% if(musalla.logo_url){ %><img src="<%= musalla.logo_url %>" alt="<%= musalla.name %> logo"><% } else { %>⌂<% } %></div>
    <p class="eyebrow">COMMUNITY MUSALLA</p><h1><%= musalla.name %></h1>
    <% if(musalla.address){ %><a class="public-address" href="https://www.google.com/maps/search/?api=1&amp;query=<%= encodeURIComponent(musalla.address) %>"><%= musalla.address %></a><% } %>
  </section>
  <% if(musalla.about){ %><section class="surface public-about"><h2>About</h2><p><%= musalla.about %></p></section><% } %>
  <% if(musalla.timetable_url){ %><a class="button secondary public-timetable" href="<%= musalla.timetable_url %>" target="_blank" rel="noopener noreferrer">View prayer timetable</a><% } %>
  <section class="surface public-action">
    <% if(!user){ %><h2>Join the community</h2><p>Sign in to request membership and interact with the Musalla app.</p><a class="button" href="<%= joinUrl %>">Sign in to join</a>
    <% } else if(membership?.status==='active'){ %><h2>You are a member</h2><p>Open the app to view the imam roster and participate.</p><a class="button" href="/musallas/<%= musalla.id %>">Open Musalla</a>
    <% } else if(membership?.status==='pending'){ %><h2>Request pending</h2><p>An administrator will review your membership request.</p><a class="button secondary" href="/">Go to dashboard</a>
    <% } else { %><h2>Join the community</h2><p>Request membership to interact with this Musalla in the app.</p><a class="button" href="<%= joinUrl %>">Request membership</a><% } %>
  </section>
</main>
<%- include('partials/foot') %>

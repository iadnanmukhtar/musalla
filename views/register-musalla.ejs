<%- include('partials/head',{title:'Register a Musalla'}) %><%- include('partials/nav') %>
<main>
  <% if(canCancel){ %><a class="back" href="/">‹ Cancel and return home</a><% } %>
  <header class="page-head"><p class="eyebrow">NEW MUSALLA</p><h1>Register a Musalla</h1><p><%= isSuperAdminRegistration?'Add a new Musalla to the platform. You can manage it immediately after registration.':'Submit the Musalla for super-admin review. Your initial membership will remain pending until approved.' %></p></header>
  <form action="/musallas" method="post" class="surface stack">
    <label>Name<input name="name" required maxlength="150" placeholder="Community Musalla"></label>
    <label>Address<input name="address" maxlength="300" placeholder="Street address"></label>
    <label>Prayer timetable or app link<input name="timetable_url" type="url" placeholder="https://..."></label>
    <input type="hidden" name="timezone" value="America/Chicago">
    <button class="button">Submit Musalla</button>
    <% if(canCancel){ %><a class="button secondary" href="/">Cancel</a><% } %>
  </form>
</main>
<%- include('partials/foot') %>

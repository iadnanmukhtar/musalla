<%- include('partials/head',{title:'Home'}) %><%- include('partials/nav') %>
<main><header class="page-head"><p class="eyebrow">ASSALAMU ALAIKUM</p><h1><%= user.name.split(' ')[0] %></h1><p>Where would you like to serve today?</p></header><section><div class="section-title"><h2>Your musallas</h2><span id="musalla-count"><%= musallas.length %></span></div><label class="content-filter"><span class="sr-only">Filter Musallas</span><input id="musalla-filter" type="search" placeholder="Find a Musalla" autocomplete="off"></label><div class="card-list" id="musalla-list"><% musallas.forEach(m=>{ %><a class="musalla-card" data-musalla-card data-search="<%= `${m.name} ${m.address}`.toLowerCase() %>" href="/musallas/<%= m.id %>"><div class="mosque-icon"><% if(m.logo_url){ %><img src="<%= m.logo_url %>" alt=""><% } else { %>⌂<% } %></div><div><h3><%= m.name %></h3><p><%= m.address || 'Address not set' %></p><small><%= m.role.split(',').join(' · ')||'Member' %></small></div><b>›</b></a><% }) %><% if(!musallas.length){ %><div class="empty">You do not have an approved Musalla membership yet.</div><% } %><div class="empty" id="no-filter-results" hidden>No Musallas match your search.</div></div></section><% if(requests.length){ %><section class="request-statuses"><div class="section-title"><h2>Membership requests</h2><span><%= requests.length %></span></div><div class="surface"><% requests.forEach(request=>{ %><div class="request-status"><b><%= request.name %></b><span class="status-chip <%= request.status %>"><%= request.status %></span></div><% }) %></div></section><% } %><details class="create-panel"><summary>＋ Register another Musalla</summary><form action="/musallas" method="post" class="stack"><label>Name<input name="name" required placeholder="Community Musalla"></label><label>Address<input name="address" placeholder="Street address"></label><label>Prayer timetable or app link<input name="timetable_url" type="url" placeholder="https://..."></label><input type="hidden" name="timezone" value="America/Chicago"><button class="button">Create Musalla</button></form></details></main>
<script src="/dashboard.js"></script><%- include('partials/foot') %>

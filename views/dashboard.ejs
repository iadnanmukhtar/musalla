<%- include('partials/head',{title:'Home'}) %><%- include('partials/nav') %>
<main><header class="page-head"><p class="eyebrow">al-salamu alaykum</p><h1><%= user.name.split(' ')[0] %></h1><p>Where would you like to serve today?</p></header><section><div class="section-title"><h2>Your musallas</h2><span id="musalla-count"><%= musallas.length %></span></div><label class="content-filter"><span class="sr-only">Filter Musallas</span><input id="musalla-filter" type="search" placeholder="Find a Musalla" autocomplete="off"></label><div class="card-list" id="musalla-list"><% musallas.forEach(m=>{ %><a class="musalla-card" data-musalla-card data-search="<%= `${m.name} ${m.address}`.toLowerCase() %>" href="/musallas/<%= m.id %>"><div class="mosque-icon"><% if(m.logo_url){ %><img src="<%= m.logo_url %>" alt=""><% } else { %>⌂<% } %></div><div><h3><%= m.name %></h3><p><%= m.address || 'Address not set' %></p><small><%= m.role.split(',').join(' · ')||'Member' %></small></div><b>›</b></a><% }) %><% if(!musallas.length){ %><div class="empty">You do not have an approved Musalla membership yet.</div><% } %><div class="empty" id="no-filter-results" hidden>No Musallas match your search.</div></div></section><% if(requests.length){ %><section class="request-statuses"><div class="section-title"><h2>Membership requests</h2><span><%= requests.length %></span></div><div class="surface"><% requests.forEach(request=>{ %><div class="request-status"><div><b><%= request.name %></b><span class="status-chip <%= request.status %>"><%= request.status %></span></div><% if(request.status==='pending'){ %><form action="/membership-requests/<%= request.id %>/cancel" method="post"><input type="hidden" name="return_to" value="/"><button class="chip danger">Cancel request</button></form><% } %></div><% }) %></div></section><% } %><div class="create-panel"><a class="register-musalla-link" href="/register-musalla">＋ Register another Musalla <span>›</span></a></div></main>
<script src="/dashboard.js"></script><%- include('partials/foot') %>

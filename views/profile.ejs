<%- include('partials/head',{title:'Profile'}) %><%- include('partials/nav') %><main><header class="page-head"><p class="eyebrow">YOUR ACCOUNT</p><h1>Profile</h1><p>Help your community get to know you.</p></header><form action="/profile" method="post" enctype="multipart/form-data" class="surface stack"><label class="profile-photo-field">Profile photo<span class="profile-photo-circle"><% if(user.avatar_url){ %><img id="profile-photo-preview" src="<%= user.avatar_url %>" alt="Current profile photo"><% } else { %><span id="profile-photo-placeholder"><%= user.name[0].toUpperCase() %></span><img id="profile-photo-preview" alt="" hidden><% } %></span><input id="profile-photo-input" name="profile_photo" type="file" accept="image/png,image/jpeg,image/webp,image/gif"><small>Choose a square photo. It will be cropped to a circle.</small></label><label>Full name<input name="name" required maxlength="100" value="<%= user.name %>"></label><label>Email<input value="<%= user.email %>" disabled><small>Managed by your Google account</small></label><label>Phone number<input name="phone" type="tel" maxlength="30" value="<%= user.phone %>" placeholder="(555) 555-5555"></label><label>Brief bio<textarea name="bio" maxlength="500" rows="5" placeholder="Share a little about yourself and your experience"><%= user.bio %></textarea></label><button class="button">Save profile</button></form><form action="/logout" method="post"><button class="text-button">Sign out</button></form></main><script src="/profile.js"></script><%- include('partials/foot') %>

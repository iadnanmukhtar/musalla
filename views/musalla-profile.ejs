<%- include('partials/head',{title:'Musalla profile'}) %><%- include('partials/nav') %>
<main>
  <a class="back" href="/musallas/<%= musalla.id %>">‹ Back to <%= musalla.name %></a>
  <header class="page-head"><p class="eyebrow">MUSALLA ADMIN</p><h1>Musalla profile</h1><p>Manage the details shown to your community.</p></header>
  <form action="/musallas/<%= musalla.id %>/profile" method="post" enctype="multipart/form-data" class="surface stack">
    <label>Logo<% if(musalla.logo_url){ %><a href="/m/<%= musalla.guid %>" aria-label="View <%= musalla.name %>"><img class="logo-preview" src="<%= musalla.logo_url %>" alt="Current <%= musalla.name %> logo"></a><% } %><input name="logo" type="file" accept="image/png,image/jpeg,image/webp,image/gif"><small>PNG, JPG, WebP, or GIF. Maximum 2 MB.</small></label>
    <label>Name<input name="name" required maxlength="150" value="<%= musalla.name %>"></label>
    <label>Address<input name="address" maxlength="300" value="<%= musalla.address %>"></label>
    <label>About <span class="optional-label">Optional</span><textarea name="about" maxlength="3000" rows="6" placeholder="Tell your community about this Musalla."><%= musalla.about || '' %></textarea><small>This description appears on the public Musalla page.</small></label>
    <label>Public page<input value="/m/<%= musalla.guid %>" readonly><small><a href="/m/<%= musalla.guid %>" target="_blank">View public page</a></small></label>
    <label>Prayer timetable or app link<input name="timetable_url" type="url" value="<%= musalla.timetable_url %>" placeholder="https://..."><small>This link appears on the Musalla roster.</small></label>
    <details class="settings-panel">
      <summary><span>Salah slots</span><small>Daily opt-in slots</small></summary>
      <div class="settings-panel-content">
        <p>Choose which daily Salah slots appear on the schedule for Imam opt-in.</p>
        <% ['Fajr','Zuhr','Asr','Maghrib','Isha'].forEach(prayer => { const field=`${prayer.toLowerCase()}_enabled`; %>
          <label class="toggle-setting"><span><b><%= prayer %></b><small>Show this slot on the schedule</small></span><input type="checkbox" name="<%= field %>" value="1" <%= musalla[field]?'checked':'' %>></label>
        <% }) %>
      </div>
    </details>
    <details class="settings-panel">
      <summary><span>Jumuah</span><small>Friday prayer slots</small></summary>
      <div class="settings-panel-content">
        <p>Enable up to three Jumuah slots. On Fridays, enabled slots replace Zuhr on the imam roster.</p>
        <% [1,2,3].forEach(number => { %>
          <label class="toggle-setting"><span><b>Jumuah <%= number %></b><small>Show this slot on Fridays</small></span><input type="checkbox" name="jumuah_<%= number %>_enabled" value="1" <%= musalla[`jumuah_${number}_enabled`]?'checked':'' %>></label>
        <% }) %>
      </div>
    </details>
    <button class="button">Save profile</button>
  </form>
</main>
<%- include('partials/foot') %>

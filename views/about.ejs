      <div class="app-carousel-track">
        <figure class="app-screenshot" id="app-screenshot-1" aria-label="1 of 3: Your Musallas dashboard">
          <div class="phone-preview"><div class="phone-status"><b>9:41</b><span>● ◒</span></div><div class="preview-topbar"><span class="preview-logo"><img src="/icon.svg" width="30" height="30" alt=""></span><b>Musalla</b><span class="preview-avatar">A</span></div><div class="preview-content"><small>YOUR COMMUNITIES</small><h3>Your Musallas</h3><p>Prayer communities you belong to.</p><article class="preview-musalla-card"><span class="preview-mosque">⌂</span><div><b>Downtown Musalla</b><small>123 Community Lane</small><em>18 members · 2 Jumuah slots</em></div><span>›</span></article><article class="preview-musalla-card"><span class="preview-mosque">⌂</span><div><b>Masjid Al-Noor</b><small>45 Crescent Avenue</small><em>32 members · 1 Jumuah slot</em></div><span>›</span></article></div><div class="preview-nav"><b>⌂<small>Home</small></b><span>▦<small>Schedule</small></span><span>♙<small>Profile</small></span></div></div>
          <figcaption><b>Your communities, together</b><span>Open schedules and see each Musalla at a glance.</span></figcaption>
        </figure>

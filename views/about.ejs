          <div class="phone-preview"><div class="phone-status"><b>9:41</b><span>● ◒</span></div><div class="preview-topbar"><span class="preview-logo"><img src="/icon.svg" width="30" height="30" alt=""></span><b>Schedule</b><span class="preview-avatar">A</span></div><div class="preview-content schedule-preview"><small>WEEKLY ROSTER</small><h3>Downtown Musalla</h3><p>July 20–26</p><div class="preview-week"><div class="preview-week-head"><span></span><b>F</b><b>Z</b><b>A</b><b>M</b><b>I</b></div><div><b>Mon<small>20</small></b><i>AK</i><i class="open">＋</i><i>YM</i><i>AK</i><i class="open">＋</i></div><div><b>Tue<small>21</small></b><i>YM</i><i>AK</i><i class="open">＋</i><i>SR</i><i>YM</i></div><div><b>Wed<small>22</small></b><i class="open">＋</i><i>SR</i><i>AK</i><i>YM</i><i class="open">＋</i></div><div><b>Thu<small>23</small></b><i>SR</i><i class="open">＋</i><i>YM</i><i>AK</i><i>SR</i></div><div><b>Fri<small>24</small></b><i>AK</i><i class="gold">KH</i><i>SR</i><i>YM</i><i>AK</i></div></div></div><div class="preview-nav"><span>⌂<small>Home</small></span><b>▦<small>Schedule</small></b><span>♙<small>Profile</small></span></div></div>

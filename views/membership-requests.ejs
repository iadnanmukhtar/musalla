<%- include('partials/head',{title:'Join a Musalla'}) %><%- include('partials/nav') %>
<main><header class="page-head"><p class="eyebrow">MEMBERSHIP</p><h1>Join a Musalla</h1><p>Send a membership request to a Musalla administrator.</p></header><div class="section-title"><h2>Available musallas</h2><span id="musalla-count"><%= musallas.length %></span></div><label class="content-filter"><span class="sr-only">Filter Musallas</span><input id="musalla-filter" type="search" placeholder="Find a Musalla" autocomplete="off"></label><div class="request-musallas" id="musalla-list"><% musallas.forEach(m=>{ const invited=Number(m.id)===selectedMusallaId; %><article class="surface request-musalla <%= invited?'invited-musalla':'' %>" data-musalla-card data-search="<%= `${m.name} ${m.address}`.toLowerCase() %>"><div class="admin-musalla-info"><div class="mosque-icon"><% if(m.logo_url){ %><img src="<%= m.logo_url %>" alt=""><% } else { %>⌂<% } %></div><div><h3><%= m.name %></h3><p><%= m.address||'Address not set' %></p><% if(invited){ %><small class="invited-label">Imam invitation</small><% } %></div></div><% if(!m.status||m.status==='denied'){ %><form action="/membership-requests/<%= m.id %>" method="post"><% if(invited){ %><input type="hidden" name="requested_role" value="imam"><% } %><button class="chip"><%= invited?'Request to join as Imam':m.status==='denied'?'Request again':'Join' %></button></form><% } else if(m.status==='pending'){ %><form action="/membership-requests/<%= m.id %>/cancel" method="post"><button class="chip danger">Cancel request</button></form><% } else { %><span class="status-chip <%= m.status %>"><%= m.status %></span><% } %></article><% }) %><% if(!musallas.length){ %><div class="empty">No Musallas are currently available.</div><% } %><div class="empty" id="no-filter-results" hidden>No Musallas match your search.</div></div></main>
<script src="/dashboard.js"></script>
<%- include('partials/foot') %>

<%- include('partials/head',{title:'Join a Musalla'}) %>
<%- include('partials/nav') %>
<main>
<header class="page-head">
<p class="eyebrow">MEMBERSHIP</p>
<h1>Join a Musalla</h1>
<p>Send a membership request to a Musalla administrator.</p>
</header>
<div class="section-title">
<h2>Available musallas</h2>
<span id="musalla-count">
<%= musallas.length %>
</span>
</div>
<label class="content-filter">
<span class="sr-only">Filter Musallas</span>
<input id="musalla-filter" type="search" placeholder="Find a Musalla" autocomplete="off">
</label>
<div class="request-musallas" id="musalla-list">
<% musallas.forEach(m=>{ const invited=Number(m.id)===invitedMusallaId; const jumuahSlotCount=[1,2,3].filter(number=>m[`jumuah_${number}_enabled`]).length; %>
<article class="surface request-musalla <%= invited?'invited-musalla':'' %>" data-musalla-card data-search="<%= `${m.name} ${m.address}`.toLowerCase() %>">
<div class="admin-musalla-info">
<a class="mosque-icon musalla-logo-link" href="/m/<%= m.guid %>" aria-label="View <%= m.name %>">
<% if(m.logo_url){ %>
<img src="<%= m.logo_url %>" alt="">
<% } else { %>⌂<% } %>
</a>
<div>
<h3>
<a class="musalla-name-link" href="/m/<%= m.guid %>"><%= m.name %></a>
</h3>
<% if(m.address){ %><p><a class="maps-link" href="geo:0,0?q=<%= encodeURIComponent(m.address) %>"><%= m.address %></a></p><% } else { %><p>Address not set</p><% } %>
<small class="musalla-card-meta"><%= m.member_count %> member<%= Number(m.member_count)===1?'':'s' %> · <%= jumuahSlotCount ? `${jumuahSlotCount} Jumuah slot${jumuahSlotCount===1?'':'s'}` : 'No Jumuah slot' %></small>
<% if(invited){ %>
<small class="invited-label">Imam invitation</small>
<% } %>
</div>
</div>
<% if(!m.status||m.status==='denied'){ %>
<form action="/membership-requests/<%= m.id %>" method="post" data-confirm-title="Join <%= m.name %>?" data-confirm="A membership request will be sent to the Musalla administrators for approval." data-confirm-button="Send request">
<% if(invited){ %>
<input type="hidden" name="requested_role" value="imam">
<% } %>
<button class="chip">
<%= invited?'Request to join as Imam':m.status==='denied'?'Request again':'Join' %>
</button>
</form>
<% } else if(m.status==='pending'){ %>
<form action="/membership-requests/<%= m.id %>/cancel" method="post" data-confirm-title="Cancel membership request?" data-confirm="Your pending request to join <%= m.name %> will be withdrawn." data-confirm-button="Cancel request" data-confirm-style="danger">
<button class="chip danger">Cancel request</button>
</form>
<% } else { %>
<span class="status-chip <%= m.status %>">
<%= m.status %>
</span>
<% } %>
</article>
<% }) %>
<% if(!musallas.length){ %>
<div class="empty">No Musallas are currently available.</div>
<% } %>
<div class="empty" id="no-filter-results" hidden>No Musallas match your search.</div>
</div>
</main>
<script src="/dashboard.js">
</script>
<%- include('partials/foot') %>

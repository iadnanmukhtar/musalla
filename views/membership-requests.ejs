<%- include('partials/head',{title:'Join a Musalla'}) %><%- include('partials/nav') %>
<main><header class="page-head"><p class="eyebrow">MEMBERSHIP</p><h1>Join a Musalla</h1><p>Send a membership request to a Musalla administrator.</p></header><div class="request-musallas"><% musallas.forEach(m=>{ %><article class="surface request-musalla"><div class="admin-musalla-info"><div class="mosque-icon"><% if(m.logo_url){ %><img src="<%= m.logo_url %>" alt=""><% } else { %>⌂<% } %></div><div><h3><%= m.name %></h3><p><%= m.address||'Address not set' %></p></div></div><% if(!m.status||m.status==='denied'){ %><form action="/membership-requests/<%= m.id %>" method="post"><button class="chip"><%= m.status==='denied'?'Request again':'Request membership' %></button></form><% } else { %><span class="status-chip <%= m.status %>"><%= m.status %></span><% } %></article><% }) %><% if(!musallas.length){ %><div class="empty">No Musallas are currently available.</div><% } %></div></main>
<%- include('partials/foot') %>

<% if(user && !hideNavigation){ %>
  <nav class="bottom-nav">
    <% if(superAdminMode){ %>
      <a class="<%= path.startsWith('/super-admin')?'active':'' %>" href="/super-admin"><span class="nav-icon">⚙<% if(typeof initialApprovalCount!=='undefined'&&initialApprovalCount){ %><b class="nav-badge"><%= initialApprovalCount %></b><% } %></span>Super Admin<% if(typeof initialApprovalCount!=='undefined'&&initialApprovalCount){ %><span class="sr-only"><%= initialApprovalCount %> new Musalla<%= initialApprovalCount===1?'':'s' %> awaiting first-member approval</span><% } %></a>
      <% if(canSwitchToMember){ %><form action="/view-mode" method="post"><input type="hidden" name="mode" value="member"><button><span>⇄</span>Musalla Role</button></form><% } %>
      <a class="<%= path==='/profile'?'active':'' %>" href="/profile"><span>♙</span>Profile</a>
    <% } else { %>
      <a class="<%= path==='/'?'active':'' %>" href="/"><span>⌂</span>Home</a>
      <% if(musallaNav){ %><a class="<%= path===`/musallas/${musallaNav.id}`?'active':'' %>" href="/musallas/<%= musallaNav.id %>"><span aria-hidden="true">▦</span>Schedule</a><% } else { %><a class="<%= path==='/membership-requests'?'active':'' %>" href="/membership-requests"><span>＋</span>Join</a><% } %>
      <% if(musallaNav&&canManageMembers){ %><a class="<%= path===`/musallas/${musallaNav.id}/members`?'active':'' %>" href="/musallas/<%= musallaNav.id %>/members"><span class="nav-icon" aria-hidden="true">👥<% if(pendingApprovalCount){ %><b class="nav-badge"><%= pendingApprovalCount %></b><% } %></span>Members<% if(pendingApprovalCount){ %><span class="sr-only"><%= pendingApprovalCount %> pending approval<%= pendingApprovalCount===1?'':'s' %></span><% } %></a><% } %>
      <% if(user.is_superuser){ %><form action="/view-mode" method="post"><input type="hidden" name="mode" value="super"><button><span>⚙</span>Super Admin</button></form><% } %>
      <a class="<%= path==='/profile'?'active':'' %>" href="/profile"><span>♙</span>Profile</a>
    <% } %>
  </nav>
<% } %>
<dialog class="confirmation-dialog" id="confirmation-dialog"><div class="dialog-card"><button class="dialog-close" id="confirmation-close" type="button" aria-label="Close">×</button><p class="eyebrow">PLEASE CONFIRM</p><h2 id="confirmation-title">Confirm membership action</h2><p id="confirmation-message"></p><div class="dialog-actions"><button class="button secondary" id="confirmation-cancel" type="button">Cancel</button><button class="button danger" id="confirmation-continue" type="button">Confirm</button></div></div></dialog>
<% if(registrationConfirmation){ %><dialog class="confirmation-dialog registration-success-dialog" id="registration-success-dialog"><div class="dialog-card"><button class="dialog-close" id="registration-success-close" type="button" aria-label="Close">×</button><p class="eyebrow">REGISTRATION COMPLETE</p><h2><%= registrationConfirmation.name %> was registered</h2><p><%= registrationConfirmation.message %></p><button class="button" id="registration-success-continue" type="button">Continue</button></div></dialog><% } %>
<aside class="install-app-prompt" id="install-app-prompt" aria-labelledby="install-app-title" hidden>
  <button class="install-app-close" id="install-app-close" type="button" aria-label="Dismiss app installation prompt">×</button>
  <img src="/icon-192.png" alt="">
  <div><strong id="install-app-title">Install Musalla</strong><p id="install-app-message">Install the app for quick access from this device.</p></div>
  <button class="button" id="install-app-button" type="button">Install</button>
</aside>
</div>

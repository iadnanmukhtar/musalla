<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-WN0F9NNBRE');
</script>
<script src="/confirmation.js?v=4"></script><script src="/app-install.js?v=9"></script><script>if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js?v=11');</script></body></html>

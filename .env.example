PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-value
# Enables seeded test users and two isolated test Musallas.
TEST_MODE=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=musalla
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=musalla

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Super-admin notifications are sent to active database users with
# is_superuser=TRUE.
# For localhost with Gmail, use smtp.gmail.com, your Gmail address as
# SMTP_USER, a Google app password as SMTP_PASSWORD, and that same address
# in MAIL_FROM.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Musalla <sender@example.com>"

PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-value
NODE_ENV=development
# Enables seeded test users and two isolated test Musallas.
TEST_MODE=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=musalla
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=musalla

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Super-admin notifications. SUPER_ADMIN_EMAIL is optional because active
# superusers in musalla_users are automatically included.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Musalla <notifications@example.com>"
SUPER_ADMIN_EMAIL=
